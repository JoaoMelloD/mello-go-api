# Gere valores reais antes de rodar a API.
# JWT_SECRET deve ter pelo menos 32 bytes.
JWT_SECRET=troque-por-uma-chave-com-pelo-menos-32-bytes

# Gere com: openssl rand -base64 32
SECRET_ENCRYPTION_KEY=troque-pelo-resultado-de-openssl-rand-base64-32

JWT_EXPIRATION_MINUTES=60
APP_ENV=development
# ALLOWED_ORIGINS=http://localhost:3000
